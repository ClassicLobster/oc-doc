---
const { title = 'OpenClaw Docs', flashCards = [] } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #0b1020;
        --panel: #131a2b;
        --panel-2: #1a2238;
        --text: #eef2ff;
        --muted: #b5c0e0;
        --accent: #7dd3fc;
        --accent-2: #a78bfa;
        --border: #26314f;
        --code: #0f172a;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: linear-gradient(180deg, var(--bg), #0f172a);
        color: var(--text);
        line-height: 1.6;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px;
      }
      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        padding: 18px 20px;
        background: rgba(19,26,43,.8);
        border: 1px solid var(--border);
        border-radius: 18px;
        backdrop-filter: blur(8px);
      }
      .brand { font-weight: 800; letter-spacing: .02em; }
      .layout {
        display: grid;
        grid-template-columns: 280px minmax(0, 1fr);
        gap: 24px;
      }
      aside, main {
        background: rgba(19,26,43,.75);
        border: 1px solid var(--border);
        border-radius: 18px;
      }
      aside { padding: 20px; position: sticky; top: 24px; height: fit-content; }
      main { padding: 28px; }
      nav ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
      nav a {
        display: block;
        padding: 10px 12px;
        border-radius: 12px;
        color: var(--muted);
        background: transparent;
      }
      nav a:hover, nav a.active {
        color: var(--text);
        background: var(--panel-2);
        text-decoration: none;
      }
      .nav-section {
        margin-top: 16px;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }
      h1, h2, h3 { line-height: 1.2; }
      h1 { font-size: 2.2rem; margin-top: 0; }
      h2 { margin-top: 2rem; }
      code, pre {
        font-family: "SFMono-Regular", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
      pre {
        background: var(--code);
        border: 1px solid var(--border);
        padding: 16px;
        border-radius: 14px;
        overflow-x: auto;
      }
      :global(code) {
        background: rgba(255,255,255,.06);
        padding: .15rem .35rem;
        border-radius: .4rem;
      }
      :global(.hero) {
        padding: 24px;
        border-radius: 18px;
        background: radial-gradient(circle at top left, rgba(125,211,252,.18), transparent 35%), radial-gradient(circle at top right, rgba(167,139,250,.18), transparent 30%), var(--panel-2);
        border: 1px solid var(--border);
        margin-bottom: 24px;
      }
      :global(.muted) { color: var(--muted); }
      :global(.flash-cards) {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
      }
      :global(.flash-card-list) {
        display: grid;
        gap: 14px;
        margin: 0;
      }
      :global(.flash-card) {
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 16px 18px;
        background: rgba(15, 23, 42, .65);
      }
      :global(.flash-card summary) {
        cursor: pointer;
        font-weight: 700;
        color: var(--text);
        list-style: none;
      }
      :global(.flash-card summary::-webkit-details-marker) { display: none; }
      :global(.flash-card .answer) {
        margin-top: 10px;
        color: var(--muted);
      }
      @media (max-width: 900px) {
        .layout { grid-template-columns: 1fr; }
        aside { position: static; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header>
        <div>
          <div class="brand">OpenClaw Docs</div>
          <div class="muted">Static Astro site for GitHub Pages</div>
        </div>
        <a href="https://github.com/ClassicLobster/oc-doc">GitHub Repo</a>
      </header>
      <div class="layout">
        <aside>
          <nav>
            <ul>
              <li><a href={baseUrl} class={Astro.url.pathname === baseUrl ? 'active' : ''}>Home</a></li>
            </ul>

            <div class="nav-section">OpenClaw</div>
            <ul>
              <li><a href={`${baseUrl}docs/how-openclaw-works/`} class={Astro.url.pathname.includes('/docs/how-openclaw-works') ? 'active' : ''}>How OpenClaw Works</a></li>
              <li><a href={`${baseUrl}docs/architecture/`} class={Astro.url.pathname.includes('/docs/architecture') ? 'active' : ''}>Architecture</a></li>
              <li><a href={`${baseUrl}docs/channels-sessions-memory/`} class={Astro.url.pathname.includes('/docs/channels-sessions-memory') ? 'active' : ''}>Channels, Sessions, Memory</a></li>
              <li><a href={`${baseUrl}docs/context/`} class={Astro.url.pathname.includes('/docs/context') ? 'active' : ''}>Context</a></li>
              <li><a href={`${baseUrl}docs/automation/`} class={Astro.url.pathname.includes('/docs/automation') ? 'active' : ''}>Automation</a></li>
            </ul>

            <div class="nav-section">Claude</div>
            <ul>
              <li><a href={`${baseUrl}docs/claude-subagents/`} class={Astro.url.pathname.includes('/docs/claude-subagents') ? 'active' : ''}>Claude Subagents</a></li>
            </ul>

            <div class="nav-section">AI</div>
            <ul>
              <li><a href={`${baseUrl}docs/ai-inference/`} class={Astro.url.pathname.includes('/docs/ai-inference') ? 'active' : ''}>AI Inference</a></li>
              <li><a href={`${baseUrl}docs/ai-tokenization/`} class={Astro.url.pathname.includes('/docs/ai-tokenization') ? 'active' : ''}>Tokenization</a></li>
              <li><a href={`${baseUrl}docs/ai-transformers-attention/`} class={Astro.url.pathname.includes('/docs/ai-transformers-attention') ? 'active' : ''}>Transformers and Attention</a></li>
              <li><a href={`${baseUrl}docs/ai-attention-is-all-you-need/`} class={Astro.url.pathname.includes('/docs/ai-attention-is-all-you-need') ? 'active' : ''}>Attention Is All You Need</a></li>
              <li><a href={`${baseUrl}docs/ai-prompt-caching/`} class={Astro.url.pathname.includes('/docs/ai-prompt-caching') ? 'active' : ''}>Prompt Caching</a></li>
              <li><a href={`${baseUrl}docs/ai-embeddings/`} class={Astro.url.pathname.includes('/docs/ai-embeddings') ? 'active' : ''}>Embeddings</a></li>
              <li><a href={`${baseUrl}docs/ai-fine-tuning/`} class={Astro.url.pathname.includes('/docs/ai-fine-tuning') ? 'active' : ''}>Fine-Tuning</a></li>
              <li><a href={`${baseUrl}docs/ai-batching-kv-cache/`} class={Astro.url.pathname.includes('/docs/ai-batching-kv-cache') ? 'active' : ''}>Batching and KV Cache</a></li>
              <li><a href={`${baseUrl}docs/ai-pytorch-vs-tensorflow/`} class={Astro.url.pathname.includes('/docs/ai-pytorch-vs-tensorflow') ? 'active' : ''}>PyTorch vs TensorFlow</a></li>
            </ul>
          </nav>
        </aside>
        <main>
          <slot />
          {flashCards.length > 0 && (
            <section class="flash-cards">
              <h2>Flash Cards</h2>
              <div class="flash-card-list">
                {flashCards.map((card) => (
                  <details class="flash-card">
                    <summary>{card.question}</summary>
                    <div class="answer">{card.answer}</div>
                  </details>
                ))}
              </div>
            </section>
          )}
        </main>
      </div>
    </div>
  </body>
</html>
